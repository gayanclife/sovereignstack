# SovereignStack Environment Configuration

# Hugging Face token for downloading models
HF_TOKEN=

# Model to run with docker-compose
MODEL_NAME=distilbert-base-uncased

# Management API port (for monitoring/visibility)
MANAGEMENT_PORT=8888

# GPU configuration
CUDA_VISIBLE_DEVICES=0

# vLLM settings
VLLM_GPU_MEMORY_UTILIZATION=0.9
